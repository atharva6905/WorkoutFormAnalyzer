# Copy this file to .env at the project root before running docker compose.

# PostgreSQL credentials used by the postgres service.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workoutdb

# Backend database connection string.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/workoutdb

# Redis connection string shared by backend and worker.
REDIS_URL=redis://redis:6379

# Shared artifact directory inside the backend and worker containers.
ARTIFACT_DIR=artifacts

# Public backend base URL used by the API when building artifact links.
BACKEND_HOST=http://localhost:8000
